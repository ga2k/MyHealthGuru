# .modules configuration file
# Module build system configuration

# Modules in dependency order (required)
MODULES := Core Gfx MyCare

# Staging directory (optional - defaults to ~/dev/stage)
STAGEDIR := ~/dev/stage

# CMake preset to use (optional - defaults to "default")
PRESET := "macOS Debug Shared"

# This is the actual executable sub-project
EXECUTABLE := true

REPO := "git@github.com:ga2k/Makefile.git"

